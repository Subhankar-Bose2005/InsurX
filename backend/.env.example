# ══════════════════════════════════════════════════════════════════════════════
# InsurX Backend — Environment Variables
# Copy this file to .env and fill in every value before running.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development


# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# REQUIRED — nothing works without this.
#
# How to get:
#   1. Go to https://console.firebase.google.com → your project
#   2. Settings gear ⚙️ → Project Settings → Service accounts tab
#   3. Click "Generate new private key" → "Generate Key"
#   4. Save the downloaded JSON as:  backend/config/serviceAccountKey.json
#   5. Add  backend/config/serviceAccountKey.json  to .gitignore
#
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json
#
# Alternative for Railway/Render — paste the entire JSON as a single-line string:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}


# ─── Firebase Storage ─────────────────────────────────────────────────────────
# Required for KYC document uploads (selfie, Aadhaar, PAN).
# Without this, uploads fall back to a placeholder URL (onboarding still works).
#
# How to get:
#   Firebase Console → Storage → Get Started → your-project.appspot.com
#   NOTE: Storage requires Blaze (pay-as-you-go) plan.
#         Free tier (Spark) does NOT include Storage.
#         Upgrade at: https://console.firebase.google.com/project/_/usage/details
#         Cost is negligible for a hackathon (first 5 GB free after upgrade).
#
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com


# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
# REQUIRED for real parametric triggers (rainfall, temperature).
# Without this, the trigger monitor uses mock weather — no real claims fire.
#
# How to get (FREE):
#   1. Sign up at https://openweathermap.org/api
#   2. Go to API Keys tab → copy "Default" key
#   3. Free tier: 1,000 calls/day — more than enough
#   4. Key activates within 10 minutes of signup
#
OPENWEATHER_API_KEY=your_openweathermap_api_key_here


# ─── WAQI (World Air Quality Index) ──────────────────────────────────────────
# REQUIRED for AQI trigger (T3: Severe AQI > 400).
# Without this, AQI readings are mocked at 85 (never triggers).
#
# How to get (FREE):
#   1. Go to https://aqicn.org/data-platform/token/
#   2. Enter your email → receive token instantly by email
#   3. No credit card, no approval needed
#
WAQI_API_KEY=your_waqi_token_here


# ─── Fast2SMS (OTP Delivery) ──────────────────────────────────────────────────
# REQUIRED for real OTP SMS delivery to Indian phone numbers.
# Without this, OTP is printed to server console (enter it manually in the app).
#
# How to get (FREE):
#   1. Sign up at https://www.fast2sms.com
#   2. Dashboard → Dev API → API Key
#   3. Free tier: 38 SMS credits on signup, no credit card needed
#   4. Buy more credits at ₹1/SMS if needed
#
FAST2SMS_API_KEY=your_fast2sms_api_key_here


# ─── Razorpay (Premium Collection — TEST MODE) ────────────────────────────────
# REQUIRED for the Razorpay payment screen to open correctly.
# Test mode = real API calls, fake money. No KYC required.
#
# How to get (FREE test mode):
#   1. Sign up at https://razorpay.com → Dashboard
#   2. Toggle to TEST MODE (top-right of dashboard)
#   3. Settings → API Keys → Generate Test Key
#   4. Copy Key ID (rzp_test_xxxx) and Key Secret
#
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_here


# ─── Razorpay Route (Payout to Workers — TEST MODE) ──────────────────────────
# Required for REAL automated UPI payouts to workers via Razorpay Payouts API.
# Without this, payouts are simulated (claims show as "paid" with mock IDs).
#
# How to get:
#   1. Razorpay Dashboard → Products → Route (Payouts)
#   2. Apply for Route activation (requires business PAN + GST — for real use)
#   3. In TEST MODE, Razorpay provides a virtual account number automatically
#      after Route is enabled — check Dashboard → Payouts → Settings
#
# ⚠️  FOR HACKATHON DEMO: Leave this blank.
#      The demo payout seeder (Earnings screen → "Demo Payout" button)
#      creates realistic paid claims with Razorpay-format IDs without needing
#      a real account number. Judges see the full payout flow.
#
RAZORPAY_ACCOUNT_NUMBER=
# Example when enabled: RAZORPAY_ACCOUNT_NUMBER=4564560012345678


# ─── ML Service (Python Flask — Fraud Detection) ─────────────────────────────
# Required for REAL fraud scoring using LSTM + XGBoost models.
# Without this, fraud scores default to 0.1 (clean) and claims auto-approve.
#
# How to run locally:
#   cd models
#   pip install flask numpy joblib tensorflow scikit-learn
#   python app.py
#   → Server starts on http://localhost:5001
#
# How to deploy (Railway — FREE tier):
#   1. railway.app → New Project → Deploy from GitHub → select /models folder
#   2. Set start command: python app.py
#   3. Copy the Railway URL below
#
ML_SERVICE_URL=http://localhost:5001
# ML_SERVICE_URL=https://your-ml-service.up.railway.app


# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API.
# For Expo Go on local network, add your machine's LAN IP:
#   exp://192.168.1.x:8081
#
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,exp://localhost:19000,exp://localhost:8081


# ══════════════════════════════════════════════════════════════════════════════
# MOBILE: set EXPO_PUBLIC_API_URL in mobile/.env
# ══════════════════════════════════════════════════════════════════════════════
# mobile/.env contents:
#   EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:5000
#
# Find your local IP:
#   Windows: ipconfig → IPv4 Address
#   Mac/Linux: ifconfig | grep "inet "
#
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:5000
# Use your machine's LAN IP, NOT localhost, so the Android/iOS device can reach it.
